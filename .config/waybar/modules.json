{
  
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
        "active": "ΎΕΣ",
        "default": "ΎΕΣ",
        "empty": "ΎΕΣ"
        },
        "persistent-workspaces": {
         "*": [
           1,
           2,
           3,
           4,
           5,
           6,
           7
         ]
         }
    },
  
    "hyprland/workspaces#pacman": {
        "active-only": false,
        "all-outputs": true,
        "format": "{icon}",
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "show-special": false,
        "persistent-workspaces": {
            "*": 5
        },
        "format-icons": {
            "active": "<span font='12'>≤░χψ</span>",
            "empty": "<span font='8'>ΎΕΣ</span>",
            "default": "≤░Λι"
        }
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
            "Alacritty",
            "kitty"
        ],
        "app_ids-mapping": {
            "firefoxdeveloperedition": "firefox-developer-edition"
        },
        "rewrite": {
            "Firefox Web Browser": "Firefox",
            "Foot Server": "Terminal"
        }
    },
     "pulseaudio": {
         "format": "{icon}  {volume}%",
         "format-bluetooth": "{icon} {volume}% ΎΛΦ {format_source}",
         "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
         "format-icons": {
           "car": "ΎΗ╣",
           "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
           "hands-free": "ΎΨΡ",
           "headphone": "ΎΑξ",
           "headset": "ΎΨΡ",
           "phone": "ΎΓΧ",
           "portable": "ΎΓΧ"
         },
         "format-muted": "Ύγσ {format_source}",
         "format-source": "ΎΕ░ {volume}%",
         "format-source-muted": "ΎΕ▒",
         "on-click": "pavucontrol"
    },
    "custom/keybindings": {
        "format": "ΎΕε",
        "on-click": "~/.config/hypr/scripts/keybinding.sh",
        "tooltip": false
    },
    "custom/exit": {
        "format": "ΎΑΣ",
        "on-click": "~/.config/hypr/scripts/powermenu.sh",
        "on-click-right": "hyprlock"
    },
    "hyprland/window": {
        "format": "{class}",
        "separate-outputs": true,
        "rewrite": {
            "(.*?)-\\s*YouTube(.*)": "Youtube ≤░ΩΔ",
            "(.*?)-\\s*chatgpt(.*)": "ChatGPT ≤░ξ║",
            "(.*?)-\\s*grok(.*)": "Grok ≤░ηψ",
            "(.*?)-\\s*x(.*)": "x.com ΎΓβ",
            "brave-web.whatsapp.com__-Default": "Whatsapp ΎΙ▓",
            "(.*?)-\\s*music(.*)": "YT M├╝zik ≤░ΟΙ",
            "(.*?)-\\s*m365(.*)": "Office 365 ΎΘΓ",
            "(.*?)-\\s*github(.*)": "Github ≤░Λν",
            "brave-www.mathcha.io__editor-Default": "Math Editor ΎΒΑ",
            "(.*?)-\\s*gemini(.*)": "Gemini ≤░ηψ",
            "(.*?)-\\s*mail(.*)": "Mail ΎΔι",
            "(.*?)-\\s*open.spotify(.*)": "Spotify ΎΗ╝",
            "(.*?)-\\s*hurawatchtv(.*)": "Film ≤░ΟΗ",
            "(.*?)-\\s*claude.ai(.*)": "Claude"

        },
        "icon": false,
        "max-length": 30,
        "icon-size": 15
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "rotate": 0,
        "format-icons": {
            "activated": "\udb80\udd76",
            "deactivated": "\udb81\udeca"
        },
        "justify": "center",
        "tooltip": "true"
    },
    "custom/media": {
        "exec": "playerctl metadata --format '{{ artist }} - {{ title }}' --player=mpv",
        "format": "ΎΑΒ",
        "tooltip": true,
        "tooltip-format": "{}",
        "interval": 1,
        "on-click": "playerctl play-pause --player=mpv",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "return-type": "string"
    },
    "custom/notification": {
        "tooltip": false,
        "format": "ΌγΡ",
        "on-click": "swaync-client -t -sw",
        "escape": true
    },
    "clock": {
        "format": "{:L%A %H:%M}",
        "format-alt": "{:L%a, %d %b %Y %H:%M } ",
        "interval": 1,
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "format": {
                "today": "<span color='#fAfBfC'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "shift_down",
            "on-click": "shift_up"
        }
    },
    "network": {
        "format-wifi": "ΎΘτ",
        "format-ethernet": "Ό╝Κ",
        "format-disconnected": "ΌυΒ",
        "tooltip-format-disconnected": "Error",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
        "tooltip-format-ethernet": "{ifname} ΏθΨπ ",
        "on-click": "kitty nm-connection-editor",
        "on-click-right": "kitty nmtui"
    },
    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ≤░ΓΕ",
        "format-plugged": "{capacity}% ≤░ΓΕ Όυφ",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "≤░Β╗",
            "≤░Β╝",
            "≤░Β╛",
            "≤░ΓΑ",
            "≤░ΓΓ",
            "≤░Β╣"
        ]
    },
    "custom/pacman": {
        "format": "≤░Ζλ {}",
        "interval": 3600,
        "exec": "checkupdates | wc -l",
        "exec-if": "exit 0",
        "on-click": "kitty sh -c 'yay -Syu; echo Bitti -Enter ; read'; pkill -SIGRTMIN+8 waybar",
        "signal": 8,
        "tooltip": false
    },
    "cpu": {
        "interval": 10,
        "format": "≤░Ξδ {usage}%",
        "rotate": 0,
        "format-alt": "{icon0}{icon1}{icon2}{icon3}",
        "format-icons": [
            " ",
            "έΨΓ",
            "έΨΔ",
            "έΨΕ",
            "έΨΖ",
            "έΨΗ",
            "έΨΘ",
            "έΨΙ"
        ]
    },
    "memory": {
        "states": {
            "c": 90,
            "h": 60,
            "m": 30
        },
        "interval": 10,
        "format": "\udb83\udf86 {used}GB",
        "rotate": 0,
        "format-m": "\udb83\udf85 {used}GB",
        "format-h": "\udb81\udcc5 {used}GB",
        "format-c": "\uf421 {used}GB",
        "format-alt": "\udb83\udf86 {percentage}%",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "\udb83\udf86 Memory usage: {percentage}%\n\ue266 Used: {used:0.2f}GB / {total:0.2f}GB\n\uf85a Available: {avail:0.2f}GB\n\uf233 Swap used: {swapUsed:0.2f}GB / {swapTotal:0.2f}GB ({swapPercentage}%)"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "ΎΜΚ"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 10
    }
}