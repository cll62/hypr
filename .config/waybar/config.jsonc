{
    "include": "$HOME/.config/waybar/modules.json",
    "layer": "top",
    "position": "top",
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "reload_style_on_change": true,
    "modules-left": [
        "clock",
        "custom/keybindings",
        "hyprland/window"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "tray",
        "custom/media",
        "custom/pacman",
        "cpu",
        "memory",
        "network",
        "pulseaudio",
        "battery",
        "idle_inhibitor",
        "custom/notification",
        "custom/exit"
    ]
}
