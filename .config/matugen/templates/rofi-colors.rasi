* {
    background:     {{colors.surface.default.hex}}B3;         
    background-alt: {{colors.surface_container.default.hex}}B3;
    foreground:     {{colors.on_surface.default.hex}}FF;      
    selected:       {{colors.primary.default.hex}}B3;
    active:         {{colors.secondary.default.hex}}B3;
    urgent:         {{colors.error.default.hex}}B3;
}
